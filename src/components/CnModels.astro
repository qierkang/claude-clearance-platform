---
/**
 * "模型还是中国的好" promo for domestic LLMs (DeepSeek / GLM):
 * a slim strip of outbound name-only links rendered below the
 * "How the check works" section.
 *
 * Outbound clicks are tagged for GA via data-ga-* (see src/scripts/track.ts).
 */
import { useTranslations, type Lang } from '../i18n/ui';
import { CN_MODELS } from '../config/cn-models';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="cn-models" aria-label={t('cnModels.label')}>
  <p class="cn-slogan">{t('cnModels.slogan')}</p>
  <div class="cn-links">
    {
      CN_MODELS.map((m) => (
        <a
          class="cn-link"
          href={m.url}
          target="_blank"
          rel="noopener noreferrer"
          data-ga-event="cn_model_click"
          data-ga-id={m.id}
        >
          {m.name}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14" />
            <path d="m13 6 6 6-6 6" />
          </svg>
        </a>
      ))
    }
  </div>
</section>

<style>
  .cn-models {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 14px;
    padding: 6px 0 10px;
  }

  /* slogan ribbon, matches the hero "credit" pill */
  .cn-slogan {
    margin: 0;
    font-family: var(--serif);
    font-weight: 700;
    font-size: 0.92rem;
    letter-spacing: 0.06em;
    color: var(--accent-strong);
    background: var(--surface);
    border: 1px solid color-mix(in srgb, var(--accent) 35%, var(--border));
    border-radius: 999px;
    padding: 7px 14px;
    box-shadow: var(--shadow-sm);
  }

  .cn-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  .cn-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 15px;
    border-radius: 999px;
    background: var(--accent-soft);
    border: 1px solid color-mix(in srgb, var(--accent) 25%, var(--border));
    color: var(--accent-strong);
    font-size: 0.88rem;
    font-weight: 650;
    transition:
      background 0.2s,
      color 0.2s,
      transform 0.12s;
  }
  .cn-link:hover {
    text-decoration: none;
    background: var(--accent);
    color: #fff;
    transform: translateY(-1px);
  }
  .cn-link svg {
    width: 12px;
    height: 12px;
  }
</style>
