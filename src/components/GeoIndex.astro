---
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const isZh = lang === 'zh';

const labels = isZh
  ? {
      title: 'SEO / GEO 检索入口',
      sub: '为搜索引擎和 AI 检索引擎补齐可抓取的信息层，明确这个站点检测什么、怎么检测、哪些接口可读。',
      blocks: [
        ['核心主题', 'Claude 环境风险检测、Claude 中国用户信号、浏览器本地指纹、出口 IP 估算'],
        ['可读文件', 'llms.txt、geo-index.json、sitemap-index.xml、结构化 FAQ'],
        ['机器接口', '/api/check、/api/messages、/api/stats/visit'],
      ],
      links: [
        ['LLMs.txt', '/llms.txt'],
        ['GEO JSON', '/geo-index.json'],
        ['Sitemap', '/sitemap-index.xml'],
        ['API JSON', '/api/check?format=json'],
      ],
    }
  : {
      title: 'SEO / GEO Discovery',
      sub: 'A crawlable information layer for search engines and AI answer engines: what this site checks, how it works, and which endpoints are readable.',
      blocks: [
        ['Core topics', 'Claude environment risk check, Claude China-user signals, browser-local fingerprints, network-exit estimate'],
        ['Readable files', 'llms.txt, geo-index.json, sitemap-index.xml, structured FAQ'],
        ['Machine endpoints', '/api/check, /api/messages, /api/stats/visit'],
      ],
      links: [
        ['LLMs.txt', '/llms.txt'],
        ['GEO JSON', '/geo-index.json'],
        ['Sitemap', '/sitemap-index.xml'],
        ['API JSON', '/api/check?format=json'],
      ],
    };
---

<section id="geo-sec" class="geo-index" aria-labelledby="geo-title">
  <div class="section-head">
    <h2 id="geo-title">{labels.title}</h2>
    <p>{labels.sub}</p>
  </div>

  <div class="geo-index__grid">
    {labels.blocks.map(([title, body]) => (
      <article class="geo-index__item">
        <h3>{title}</h3>
        <p>{body}</p>
      </article>
    ))}
  </div>

  <div class="geo-index__links" aria-label={labels.title}>
    {labels.links.map(([label, href]) => (
      <a href={href}>{label}</a>
    ))}
  </div>
</section>

<style>
  .geo-index__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }
  .geo-index__item {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    padding: 14px;
    box-shadow: var(--shadow-sm);
  }
  .geo-index__item h3 {
    margin: 0 0 7px;
    font-size: 0.95rem;
    line-height: 1.3;
  }
  .geo-index__item p {
    margin: 0;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.55;
  }
  .geo-index__links {
    margin-top: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
  }
  .geo-index__links a {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    background: var(--bg);
    color: var(--text);
    font-size: 0.82rem;
    font-weight: 650;
  }
  .geo-index__links a:hover {
    color: #fff;
    background: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }
  @media (max-width: 760px) {
    .geo-index__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
